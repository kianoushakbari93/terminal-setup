# =============================================================================
#  ~/.p10k.zsh - Powerlevel10k configuration (Catppuccin Mocha)
#  Rainbow + round "pill" prompt, truecolor. Rendered by terminal-setup.
#  Glyphs are injected via the `glyph` filter so they are never stripped empty.
# =============================================================================

# Temporarily change options.
'builtin' 'local' '-a' 'p10k_config_opts'
[[ ! -o 'aliases'         ]] || p10k_config_opts+=('aliases')
[[ ! -o 'sh_glob'         ]] || p10k_config_opts+=('sh_glob')
[[ ! -o 'no_brace_expand' ]] || p10k_config_opts+=('no_brace_expand')
'builtin' 'setopt' 'no_aliases' 'no_sh_glob' 'brace_expand'

() {
  emulate -L zsh -o extended_glob

  unset -m '(POWERLEVEL9K_*|DEFAULT_USER)~POWERLEVEL9K_GITSTATUS_DIR'

  # ---- Catppuccin Mocha palette (sourced from vars) -----------------------
  local rosewater='{{ ts_zsh_palette.rosewater }}' flamingo='{{ ts_zsh_palette.flamingo }}' pink='{{ ts_zsh_palette.pink }}' mauve='{{ ts_zsh_palette.mauve }}'
  local red='{{ ts_zsh_palette.red }}'       maroon='{{ ts_zsh_palette.maroon }}'    peach='{{ ts_zsh_palette.peach }}' yellow='{{ ts_zsh_palette.yellow }}'
  local green='{{ ts_zsh_palette.green }}'     teal='{{ ts_zsh_palette.teal }}'      sky='{{ ts_zsh_palette.sky }}'   sapphire='{{ ts_zsh_palette.sapphire }}'
  local blue='{{ ts_zsh_palette.blue }}'      lavender='{{ ts_zsh_palette.lavender }}'  text='{{ ts_zsh_palette.text }}'  subtext1='{{ ts_zsh_palette.subtext1 }}'
  local subtext0='{{ ts_zsh_palette.subtext0 }}'  overlay2='{{ ts_zsh_palette.overlay2 }}'  overlay1='{{ ts_zsh_palette.overlay1 }}' overlay0='{{ ts_zsh_palette.overlay0 }}'
  local surface2='{{ ts_zsh_palette.surface2 }}'  surface1='{{ ts_zsh_palette.surface1 }}'  surface0='{{ ts_zsh_palette.surface0 }}'
  local base='{{ ts_zsh_palette.base }}'      mantle='{{ ts_zsh_palette.mantle }}'    crust='{{ ts_zsh_palette.crust }}'

  # ---- Prompt structure ---------------------------------------------------
  typeset -g POWERLEVEL9K_LEFT_PROMPT_ELEMENTS=(
    os_icon                 # apple logo
    dir                     # current directory
    vcs                     # git status
    newline                 # \n
    prompt_char             # prompt symbol (green ok / red error)
  )
  typeset -g POWERLEVEL9K_RIGHT_PROMPT_ELEMENTS=(
    status                  # exit code of the last command
    command_execution_time  # previous command duration
    background_jobs         # presence of background jobs
    direnv                  # direnv status
    node_version            # node.js version (when relevant)
    time                    # current time
  )

  # ---- Global look --------------------------------------------------------
  typeset -g POWERLEVEL9K_MODE=nerdfont-v3
  typeset -g POWERLEVEL9K_ICON_PADDING=moderate
  typeset -g POWERLEVEL9K_BACKGROUND=                  # default: transparent
  typeset -g POWERLEVEL9K_VISUAL_IDENTIFIER_EXPANSION='${P9K_VISUAL_IDENTIFIER}'
  typeset -g POWERLEVEL9K_PROMPT_ADD_NEWLINE=true     # blank line between prompts

  # ---- Round "pill" separators & caps (matches tmux rounded modules) ------
  typeset -g POWERLEVEL9K_LEFT_SEGMENT_SEPARATOR='{{ "right_half_circle" | glyph }}'
  typeset -g POWERLEVEL9K_RIGHT_SEGMENT_SEPARATOR='{{ "left_half_circle" | glyph }}'
  typeset -g POWERLEVEL9K_LEFT_SUBSEGMENT_SEPARATOR='{{ "right_half_circle_thin" | glyph }}'
  typeset -g POWERLEVEL9K_RIGHT_SUBSEGMENT_SEPARATOR='{{ "left_half_circle_thin" | glyph }}'
  typeset -g POWERLEVEL9K_LEFT_PROMPT_FIRST_SEGMENT_START_SYMBOL='{{ "left_half_circle" | glyph }}'
  typeset -g POWERLEVEL9K_LEFT_PROMPT_LAST_SEGMENT_END_SYMBOL='{{ "right_half_circle" | glyph }}'
  typeset -g POWERLEVEL9K_RIGHT_PROMPT_FIRST_SEGMENT_START_SYMBOL='{{ "left_half_circle" | glyph }}'
  typeset -g POWERLEVEL9K_RIGHT_PROMPT_LAST_SEGMENT_END_SYMBOL='{{ "right_half_circle" | glyph }}'

  # ---- os_icon (leading pill) ---------------------------------------------
  typeset -g POWERLEVEL9K_OS_ICON_BACKGROUND=$surface2
  typeset -g POWERLEVEL9K_OS_ICON_FOREGROUND=$mauve

  # ---- prompt_char (no pill, on its own line) -----------------------------
  typeset -g POWERLEVEL9K_PROMPT_CHAR_BACKGROUND=
  typeset -g POWERLEVEL9K_PROMPT_CHAR_OK_{VIINS,VICMD,VIVIS,VIOWR}_FOREGROUND=$green
  typeset -g POWERLEVEL9K_PROMPT_CHAR_ERROR_{VIINS,VICMD,VIVIS,VIOWR}_FOREGROUND=$red
  typeset -g POWERLEVEL9K_PROMPT_CHAR_{OK,ERROR}_VIINS_CONTENT_EXPANSION='{{ "prompt_ok" | glyph }}'
  typeset -g POWERLEVEL9K_PROMPT_CHAR_{OK,ERROR}_VICMD_CONTENT_EXPANSION='{{ "prompt_vicmd" | glyph }}'
  typeset -g POWERLEVEL9K_PROMPT_CHAR_{OK,ERROR}_VIVIS_CONTENT_EXPANSION='V'
  typeset -g POWERLEVEL9K_PROMPT_CHAR_{OK,ERROR}_VIOWR_CONTENT_EXPANSION='{{ "overwrite" | glyph }}'
  typeset -g POWERLEVEL9K_PROMPT_CHAR_OVERWRITE_STATE=true
  typeset -g POWERLEVEL9K_PROMPT_CHAR_LEFT_{LEFT,RIGHT}_WHITESPACE=
  typeset -g POWERLEVEL9K_PROMPT_CHAR_LEFT_PROMPT_FIRST_SEGMENT_START_SYMBOL=
  typeset -g POWERLEVEL9K_PROMPT_CHAR_LEFT_PROMPT_LAST_SEGMENT_END_SYMBOL=

  # ---- dir ----------------------------------------------------------------
  typeset -g POWERLEVEL9K_DIR_BACKGROUND=$blue
  typeset -g POWERLEVEL9K_DIR_FOREGROUND=$crust
  typeset -g POWERLEVEL9K_DIR_SHORTENED_FOREGROUND=$mantle
  typeset -g POWERLEVEL9K_DIR_ANCHOR_FOREGROUND=$crust
  typeset -g POWERLEVEL9K_DIR_ANCHOR_BOLD=true
  typeset -g POWERLEVEL9K_SHORTEN_STRATEGY=truncate_to_unique
  typeset -g POWERLEVEL9K_SHORTEN_DELIMITER=
  typeset -g POWERLEVEL9K_DIR_MAX_LENGTH=80
  typeset -g POWERLEVEL9K_DIR_MIN_COMMAND_COLUMNS=40
  typeset -g POWERLEVEL9K_DIR_MIN_COMMAND_COLUMNS_PCT=50
  typeset -g POWERLEVEL9K_DIR_HYPERLINK=false
  typeset -g POWERLEVEL9K_DIR_SHOW_WRITABLE=v3
  typeset -g POWERLEVEL9K_DIR_CLASSES=()

  # ---- vcs (git) - pill color reflects repo state -------------------------
  typeset -g POWERLEVEL9K_VCS_CLEAN_BACKGROUND=$green
  typeset -g POWERLEVEL9K_VCS_CLEAN_FOREGROUND=$crust
  typeset -g POWERLEVEL9K_VCS_MODIFIED_BACKGROUND=$yellow
  typeset -g POWERLEVEL9K_VCS_MODIFIED_FOREGROUND=$crust
  typeset -g POWERLEVEL9K_VCS_UNTRACKED_BACKGROUND=$teal
  typeset -g POWERLEVEL9K_VCS_UNTRACKED_FOREGROUND=$crust
  typeset -g POWERLEVEL9K_VCS_CONFLICTED_BACKGROUND=$red
  typeset -g POWERLEVEL9K_VCS_CONFLICTED_FOREGROUND=$crust
  typeset -g POWERLEVEL9K_VCS_LOADING_BACKGROUND=$surface1
  typeset -g POWERLEVEL9K_VCS_LOADING_FOREGROUND=$overlay1
  typeset -g POWERLEVEL9K_VCS_BRANCH_ICON='{{ "git_branch" | glyph }} '
  typeset -g POWERLEVEL9K_VCS_UNTRACKED_ICON='?'
  typeset -g POWERLEVEL9K_VCS_BACKENDS=(git)

  # ---- status (only on error) ---------------------------------------------
  typeset -g POWERLEVEL9K_STATUS_EXTENDED_STATES=true
  typeset -g POWERLEVEL9K_STATUS_OK=false
  typeset -g POWERLEVEL9K_STATUS_OK_PIPE=false
  typeset -g POWERLEVEL9K_STATUS_ERROR=true
  typeset -g POWERLEVEL9K_STATUS_ERROR_BACKGROUND=$red
  typeset -g POWERLEVEL9K_STATUS_ERROR_FOREGROUND=$crust
  typeset -g POWERLEVEL9K_STATUS_ERROR_VISUAL_IDENTIFIER_EXPANSION='{{ "cross" | glyph }}'
  typeset -g POWERLEVEL9K_STATUS_ERROR_SIGNAL_BACKGROUND=$red
  typeset -g POWERLEVEL9K_STATUS_ERROR_SIGNAL_FOREGROUND=$crust
  typeset -g POWERLEVEL9K_STATUS_ERROR_PIPE_BACKGROUND=$red
  typeset -g POWERLEVEL9K_STATUS_ERROR_PIPE_FOREGROUND=$crust

  # ---- command_execution_time ---------------------------------------------
  typeset -g POWERLEVEL9K_COMMAND_EXECUTION_TIME_THRESHOLD=3
  typeset -g POWERLEVEL9K_COMMAND_EXECUTION_TIME_PRECISION=0
  typeset -g POWERLEVEL9K_COMMAND_EXECUTION_TIME_BACKGROUND=$peach
  typeset -g POWERLEVEL9K_COMMAND_EXECUTION_TIME_FOREGROUND=$crust
  typeset -g POWERLEVEL9K_COMMAND_EXECUTION_TIME_VISUAL_IDENTIFIER_EXPANSION=''

  # ---- background_jobs ----------------------------------------------------
  typeset -g POWERLEVEL9K_BACKGROUND_JOBS_BACKGROUND=$sapphire
  typeset -g POWERLEVEL9K_BACKGROUND_JOBS_FOREGROUND=$crust
  typeset -g POWERLEVEL9K_BACKGROUND_JOBS_VISUAL_IDENTIFIER_EXPANSION=''

  # ---- direnv -------------------------------------------------------------
  typeset -g POWERLEVEL9K_DIRENV_BACKGROUND=$peach
  typeset -g POWERLEVEL9K_DIRENV_FOREGROUND=$crust

  # ---- node_version -------------------------------------------------------
  typeset -g POWERLEVEL9K_NODE_VERSION_BACKGROUND=$green
  typeset -g POWERLEVEL9K_NODE_VERSION_FOREGROUND=$crust
  typeset -g POWERLEVEL9K_NODE_VERSION_PROJECT_ONLY=true

  # ---- time ---------------------------------------------------------------
  typeset -g POWERLEVEL9K_TIME_BACKGROUND=$surface1
  typeset -g POWERLEVEL9K_TIME_FOREGROUND=$text
  typeset -g POWERLEVEL9K_TIME_FORMAT='{% raw %}%D{%H:%M:%S}{% endraw %}'
  typeset -g POWERLEVEL9K_TIME_UPDATE_ON_COMMAND=false

  # ---- Performance & behaviour --------------------------------------------
  typeset -g POWERLEVEL9K_TRANSIENT_PROMPT=always   # collapse old prompts
  typeset -g POWERLEVEL9K_INSTANT_PROMPT=quiet      # silent instant prompt
  typeset -g POWERLEVEL9K_DISABLE_HOT_RELOAD=true   # faster startup

  (( ! $+functions[p10k] )) || p10k reload
}

# Tell `p10k configure` which file it should overwrite.
typeset -g POWERLEVEL9K_CONFIG_FILE=${${(%):-%x}:a}

{% raw %}
(( ${#p10k_config_opts} )) && setopt ${p10k_config_opts[@]}
'builtin' 'unset' 'p10k_config_opts'
{% endraw %}
